            "km/l",
            "l/100km",
            null
          ]
        },
        "fonte": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "cambio": {
      "type": [
        "string",
        "null"
      ]
    },
    "cilindrada": {

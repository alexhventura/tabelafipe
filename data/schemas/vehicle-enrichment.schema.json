          "type": [
            "number",
            "null"
          ]
        },
        "unidade": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "cv",
            "hp",
            "kW",
            null
          ]
        },
        "fonte": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "torque": {
      "type": "object",

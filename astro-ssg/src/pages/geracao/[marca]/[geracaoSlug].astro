---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubSections from '../../../components/HubSections.astro';
import { getGenerationPaths, loadGenerationHub } from '../../../lib/paths.server';

export function getStaticPaths() {
  return getGenerationPaths().map(({ marca, geracaoSlug }) => ({
    params: { marca, geracaoSlug },
  }));
}

const { marca, geracaoSlug } = Astro.params;
const hub = loadGenerationHub(marca!, geracaoSlug!);
if (!hub) throw new Error(`Hub geracao not found: ${marca}/${geracaoSlug}`);
const seo = hub.seo;
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  og={{ 'og:title': seo.title, 'og:description': seo.description, 'og:url': seo.canonical }}
  twitter={{ 'twitter:card': 'summary_large_image', 'twitter:title': seo.title, 'twitter:description': seo.description }}
>
  <HubSections hub={hub} />
</BaseLayout>

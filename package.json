{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "api": "node server/index.js",
    "dev:full": "node server/index.js & vite --port=3000 --host=0.0.0.0",
    "build": "node scripts/prebuild.js && vite build",
    "bootstrap": "node scripts/bootstrap-catalog.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "db:generate": "node -e \"console.error('DEPRECATED: use npm run catalog:import'); process.exit(1)\"",
    "db:generate:fast": "node -e \"console.error('DEPRECATED: use npm run catalog:import'); process.exit(1)\"",
    "catalog:import": "npx tsx scripts/import-fipe.ts --fase tudo && npx tsx scripts/build-search-index.ts",
    "catalog:tree": "npx tsx scripts/import-fipe.ts --fase catalogo",
    "catalog:prices": "npx tsx scripts/import-fipe.ts --fase precos && npx tsx scripts/build-search-index.ts",
    "catalog:search": "npx tsx scripts/build-search-index.ts",
    "catalog:status": "node scripts/catalog-status.js",
    "db:init": "node scripts/init-fipe-db.js",
    "db:sync": "node scripts/sync-to-sqlite.js",
    "sitemap": "node scripts/generate-sitemap.js",
    "benchmark:search": "node scripts/benchmark-search.js",
    "test:search": "npx tsx scripts/test-search.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}

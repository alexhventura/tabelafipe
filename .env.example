# FIPE_API_TOKEN: Token gratuito em https://fipe.online/register (1000 req/dia)
FIPE_API_TOKEN=""

# Google AdSense — IDs dos blocos criados no painel (opcional até aprovação)
VITE_ADSENSE_SLOT_VEHICLE_TOP=""
VITE_ADSENSE_SLOT_VEHICLE_MID=""
VITE_ADSENSE_SLOT_VEHICLE_BOTTOM=""

# Delay entre requisicoes a API FIPE (ms)
FIPE_DELAY_MS="500"

# Porta da API Express + SQLite (local)
API_PORT="3001"
# FIPE_DB_PATH="./fipe.db"

# Pipeline hibrido:
#   1. npm run catalog:tree     -> JSON em src/data/fipe/
#   2. npm run db:sync          -> JSON -> fipe.db (SQLite)
#   3. npm run catalog:prices   -> precos via API + indice estatico
#   4. npm run api              -> API local /api/fipe/*
#   5. npm run dev              -> frontend (proxy /api/fipe -> :3001)
